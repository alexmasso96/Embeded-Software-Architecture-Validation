# IDE folders
.idea/

# Python cache
__pycache__/
*.pyc
*.pyo

# Virtual environments. The glob (.venv*) catches per-OS variants too —
# .venv-win and e.g. .venv-broken-windows. Never share one venv across OSes via
# the synced folder: the Windows VM rewrites a mac .venv (and vice versa).
venv/
env/
ENV/
.venv*/
.ENV/

# OS files
.DS_Store
Thumbs.db

# Test results
*.log

# Others
*.swp

# Runtime edit-lock sidecars (written when a .arch project is opened; never commit)
*.arch.lock

# Agent and IDE/Workspace configurations
.claude/
.agent/

# PyInstaller build directories
build/
build_*/
dist/

# Rust native parser build artifacts (commit the source, not the 200M+ target tree)
src/native/parser_rust/target/
# Wheel output dir used by the release build (maturin build --out target/wheels)
/target/

# Test cache and local temporary project directories
.pytest_cache/
.tmp_*/
scratch/

# Coverage artifacts
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local-only real test data (not for distribution)
ForTesting/

# Smoke tests: resources not yet committed — ignore until reviewed
Tests/smoke/

# Windows build script: distribute the app via Releases; to build, pull/fork.
build_windows.bat

# Local-only audit scratchpad (working notes, not a deliverable)
AUDIT_FINDINGS.md